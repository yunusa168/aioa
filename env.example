# ─── AIOA — Configuration d'environnement ───────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS committer .env dans Git

# ── Django ──────────────────────────────────────────────────────────────────
# Générer une clé aléatoire : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_MOI_clé_secrète_aléatoire

# True en développement, False en production
DEBUG=True

# En prod : ton-domaine.ci,www.ton-domaine.ci
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Base de données ──────────────────────────────────────────────────────────
# Développement (MySQL local)
DB_ENGINE=django.db.backends.mysql
DB_NAME=aioa_bac_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Production (PostgreSQL — décommente et remplace)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=aioa_db
# DB_USER=aioa_user
# DB_PASSWORD=mot_de_passe_postgres
# DB_HOST=localhost
# DB_PORT=5432

# ── API Mistral ───────────────────────────────────────────────────────────────
MISTRAL_API_KEY=ta_clé_api_mistral_ici
